# server
PORT=9999

# same secret as the addon
API_SECRET=change-me-to-a-strong-secret

# optional, only needed if you want absolute urls somewhere later
BASE_URL=

# cache ttl in days
CACHE_DAYS=30

# hard cutoff, in seconds
MAX_DURATION_SECONDS=600

# rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# spotify is optional. leave empty if you dont care
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# netscape cookies file for yt-dlp
COOKIES_FILE=/app/cookies/cookies.txt

# yt-dlp VBR quality: 0=best(~245kbps) 5=~130kbps 9=worst. 5 is a good tradeoff for gmod streaming
AUDIO_QUALITY=5

# dev console — set DEV_CONSOLE=1 to enable, pick a strong token
DEV_CONSOLE=0
DEV_CONSOLE_TOKEN=change-me

# rank limits are managed via the dev console panel (data/rank-limits.json)
# by default everything is unlimited — add per-rank restrictions through the UI
