# Server
PORT=9999

# Shared secret between GMod addon and this server
# Generate a strong random string and set it in both the addon and here
API_SECRET=change-me-to-a-strong-secret

# Cache duration in days
CACHE_DAYS=30

# Max video duration in seconds (600 = 10 minutes)
MAX_DURATION_SECONDS=600

# Rate limit: max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# Path to yt-dlp cookies file (Netscape format)
COOKIES_FILE=/app/cookies/cookies.txt
